# Quorum reads model API keys from the environment only (public repo — never commit real keys).

# Anthropic — required for the routing claim (Claim #1) and any Claude-tier calls.
# Get one at https://console.anthropic.com/ then:  export ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# DeepSeek (OpenAI-compatible) — required for the verification claim (Claim #2) live run.
# Endpoint defaults to https://api.deepseek.com/v1 ; model defaults to deepseek-chat.
OSSLLM_API_KEY=
OSSLLM_MODEL=deepseek-chat
OSSLLM_BASE_URL=https://api.deepseek.com/v1

# Eval safety:
#   QUORUM_EVAL_LIVE=1        # opt in to PAID calls (default off = dry-run, zero cost)
#   QUORUM_EVAL_MAX_USD=1.00  # refuse a live run whose pre-estimate exceeds this
